---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config';
---

<BaseLayout title="Contact" description="Neem contact met ons op.">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Contact</h1>
    <p class="text-gray-600 mb-8">Heb je een vraag of opmerking? Vul het formulier in en we nemen zo snel mogelijk contact met je op.</p>
    <form action="https://formspree.io/f/info@smartcontract.nl" method="POST" class="space-y-6">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Naam</label>
        <input type="text" name="name" id="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
        <input type="email" name="_replyto" id="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Bericht</label>
        <textarea name="message" id="message" rows="5" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"></textarea>
      </div>
      <input type="hidden" name="_subject" value="Nieuw bericht via SmartContract.nl" />
      <input type="text" name="_gotcha" style="display:none" />
      <button type="submit" class="w-full bg-blue-600 text-white py-3 px-6 rounded-lg font-medium hover:bg-blue-700 transition-colors">Verstuur bericht</button>
    </form>
  </div>
</BaseLayout>
